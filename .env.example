# FloodMind 配置说明
# 
# API 密钥等敏感信息请配置在 ~/.floodmind/settings.json 中
# 格式参见: floodmind/config/settings_template.json
#
# 环境变量可用作补充（优先级低于 settings.json）：
#   FLOODMIND_API_KEY  - LLM API 密钥
#   FLOODMIND_BASE_URL - LLM API 地址
#   FLOODMIND_MODEL    - 模型名称
#
# RAG 配置（可选）：
#   RAG_ENABLED=true
#   RAG_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
#   RAG_PERSIST_DIR=./data/vector_store
#   RAG_TOP_K=10
